  "components": {
    "schemas": {
      "Role": {
        "type": "string",
        "enum": [
          "admin",
          "mod",
          "user"
        ]
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "role": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Role"
              }
            ]
          },
          "id": {
            "type": "string"
          },
          "steamId": {
            "type": "string",
            "nullable": true
          },
          "username": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true
          },
          "xp": {
            "type": "number"
          },
          "balance": {
            "type": "number"
          },
          "mutedUntil": {
            "format": "date-time",
            "type": "string",
            "nullable": true
          },
          "steamTradeUrl": {
            "type": "string",
            "nullable": true
          },
          "hashedServerSeed": {
            "type": "string"
          },
          "clientSeed": {
            "type": "string"
          },
          "nonce": {
            "type": "number"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "role",
          "id",
          "steamId",
          "username",
          "avatarUrl",
          "xp",
          "balance",
          "mutedUntil",
          "steamTradeUrl",
          "hashedServerSeed",
          "clientSeed",
          "nonce",
          "createdAt",
          "updatedAt"
        ]
      },
      "UserWrappedResponse": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserResponse"
          }
        },
        "required": [
          "user"
        ]
      },
      "PublicUserResponse": {
        "type": "object",
        "properties": {
          "role": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Role"
              }
            ]
          },
          "id": {
            "type": "string"
          },
          "steamId": {
            "type": "string",
            "nullable": true
          },
          "username": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true
          },
          "xp": {
            "type": "number"
          },
          "balance": {
            "type": "number"
          },
          "mutedUntil": {
            "format": "date-time",
            "type": "string",
            "nullable": true
          },
          "steamTradeUrl": {
            "type": "string",
            "nullable": true
          },
          "hashedServerSeed": {
            "type": "string"
          },
          "clientSeed": {
            "type": "string"
          },
          "nonce": {
            "type": "number"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "role",
          "id",
          "steamId",
          "username",
          "avatarUrl",
          "xp",
          "balance",
          "mutedUntil",
          "steamTradeUrl",
          "hashedServerSeed",
          "clientSeed",
          "nonce",
          "createdAt",
          "updatedAt"
        ]
      },
      "PublicUserWrappedResponse": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/PublicUserResponse"
          }
        },
        "required": [
          "user"
        ]
      },
      "SetSteamTradeUrlBody": {
        "type": "object",
        "properties": {
          "steamTradeUrl": {
            "type": "string",
            "pattern": "/^https:\\/\\/steamcommunity\\.com\\/tradeoffer\\/new\\/\\?partner=(\\d+)&token=([a-zA-Z0-9_-]+)$/"
          }
        },
        "required": [
          "steamTradeUrl"
        ]
      },
      "SetClientSeedBody": {
        "type": "object",
        "properties": {
          "clientSeed": {
            "type": "string",
            "minLength": 1,
            "maxLength": 32
          }
        },
        "required": [
          "clientSeed"
        ]
      },
      "ChatMessageResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "isRemoved": {
            "type": "boolean"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "userId",
          "message",
          "isRemoved",
          "createdAt",
          "updatedAt"
        ]
      },
      "PartialUserResponse": {
        "type": "object",
        "properties": {
          "role": {
            "allOf": [
              {
                "$ref": "#/components/schemas/Role"
              }
            ]
          },
          "id": {
            "type": "string"
          },
          "steamId": {
            "type": "string",
            "nullable": true
          },
          "username": {
            "type": "string"
          },
          "avatarUrl": {
            "type": "string",
            "nullable": true
          },
          "xp": {
            "type": "number"
          },
          "balance": {
            "type": "number"
          },
          "mutedUntil": {
            "format": "date-time",
            "type": "string",
            "nullable": true
          },
          "steamTradeUrl": {
            "type": "string",
            "nullable": true
          },
          "hashedServerSeed": {
            "type": "string"
          },
          "clientSeed": {
            "type": "string"
          },
          "nonce": {
            "type": "number"
          }
        },
        "required": [
          "role",
          "id",
          "steamId",
          "username",
          "avatarUrl",
          "xp"
        ]
      },
      "GetMessagesResponse": {
        "type": "object",
        "properties": {
          "chatMessages": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChatMessageResponse"
            }
          },
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PartialUserResponse"
            }
          }
        },
        "required": [
          "chatMessages",
          "users"
        ]
      },
      "SendMessageBody": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          }
        },
        "required": [
          "message"
        ]
      },
      "ChatMessageWrappedResponse": {
        "type": "object",
        "properties": {
          "chatMessage": {
            "$ref": "#/components/schemas/ChatMessageResponse"
          }
        },
        "required": [
          "chatMessage"
        ]
      },
      "MuteUserBody": {
        "type": "object",
        "properties": {
          "duration": {
            "type": "number",
            "minimum": 1
          }
        },
        "required": [
          "duration"
        ]
      },
      "CrateResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "cost": {
            "type": "number"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "imageUrl",
          "cost",
          "createdAt",
          "updatedAt"
        ]
      },
      "GetCratesResponse": {
        "type": "object",
        "properties": {
          "crates": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CrateResponse"
            }
          }
        },
        "required": [
          "crates"
        ]
      },
      "CrateItemResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "crateId": {
            "type": "string"
          },
          "itemId": {
            "type": "string"
          },
          "value": {
            "type": "number"
          },
          "chance": {
            "type": "number"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "crateId",
          "itemId",
          "value",
          "chance",
          "createdAt",
          "updatedAt"
        ]
      },
      "ItemResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "imageUrl": {
            "type": "string"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name",
          "imageUrl",
          "createdAt",
          "updatedAt"
        ]
      },
      "GetCrateResponse": {
        "type": "object",
        "properties": {
          "crate": {
            "$ref": "#/components/schemas/CrateResponse"
          },
          "crateItems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CrateItemResponse"
            }
          },
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ItemResponse"
            }
          }
        },
        "required": [
          "crate",
          "crateItems",
          "items"
        ]
      },
      "OpenCrateBody": {
        "type": "object",
        "properties": {
          "count": {
            "type": "number",
            "minimum": 1,
            "maximum": 5
          }
        },
        "required": [
          "count"
        ]
      },
      "OpenCrateResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CrateItemResponse"
            }
          }
        },
        "required": [
